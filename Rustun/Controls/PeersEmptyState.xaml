<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Rustun.Controls.PeersEmptyState"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
        <x:Double x:Key="CardShadowOpacity">0.10</x:Double>
        <Thickness x:Key="CardShadowMargin">0,3,0,0</Thickness>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Center" MaxWidth="560" MinWidth="400">
        <Border
            CornerRadius="{StaticResource CardCornerRadius}"
            Background="{ThemeResource CardBackgroundFillColorDefault}"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefault}"
            Padding="20">
            <StackPanel Spacing="10" HorizontalAlignment="Center">
                <FontIcon
                    x:Name="StateIcon"
                    Glyph="&#xE7BA;"
                    FontSize="28"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="TitleBlock"
                    Style="{StaticResource SubtitleTextBlockStyle}"
                    TextAlignment="Center" />
                <TextBlock
                    x:Name="DescriptionBlock"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap"
                    TextAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
