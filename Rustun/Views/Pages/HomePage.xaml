<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Rustun.Views.Pages.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Rustun.Views.Pages"
    xmlns:controls="using:Rustun.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="VerticalSpacing">8</x:Double>
        <x:Double x:Key="CardSpacing">12</x:Double>
        <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
        <x:Double x:Key="CardShadowOpacity">0.10</x:Double>
        <Thickness x:Key="CardShadowMargin">0,3,0,0</Thickness>

        <!-- Status pill brushes (use accent only; avoids unknown theme resources) -->
        <SolidColorBrush x:Key="PillAccentBgBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.14" />
        <SolidColorBrush x:Key="PillAccentStrokeBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.70" />
        <SolidColorBrush x:Key="PillAccentTextBrush" Color="{ThemeResource SystemAccentColor}" />
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock x:Name="PageHeader" MaxWidth="1064" Margin="36,24,36,0" AutomationProperties.HeadingLevel="Level1" Style="{StaticResource TitleTextBlockStyle}" Text="VPN" />

        <ScrollView Grid.Row="1" Padding="36,0,36,0" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
            <StackPanel MaxWidth="1064" Spacing="{StaticResource CardSpacing}" Padding="0,24,0,36">
                <InfoBar
                    IsOpen="{x:Bind viewModel.IsServerInfoSet.Equals(x:False)}"
                    Severity="Warning"
                    Title="配置未完成"
                    Message="请先到“设置”填写服务器地址、端口和加密信息，然后再连接。">
                    <InfoBar.ActionButton>
                        <Button Content="去设置" Click="OpenSettings_Click" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <!-- Server info and statics -->
                <Grid x:Name="CardsGrid" ColumnSpacing="{StaticResource CardSpacing}" RowSpacing="{StaticResource CardSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <VisualStateManager.VisualStateGroups>
                        <VisualStateGroup>
                            <VisualState x:Name="WideState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="900" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="RightCard.(Grid.Column)" Value="1" />
                                    <Setter Target="RightCard.(Grid.Row)" Value="0" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="NarrowState">
                                <VisualState.StateTriggers>
                                    <AdaptiveTrigger MinWindowWidth="0" />
                                </VisualState.StateTriggers>
                                <VisualState.Setters>
                                    <Setter Target="RightCard.(Grid.Column)" Value="0" />
                                    <Setter Target="RightCard.(Grid.Row)" Value="1" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateManager.VisualStateGroups>

                    <!-- VPN Control -->
                    <Grid Grid.Column="0">
                        <!-- Faux shadow -->
                        <Border
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Background="Black"
                            Opacity="{StaticResource CardShadowOpacity}"
                            Margin="{StaticResource CardShadowMargin}"
                            IsHitTestVisible="False" />

                        <Border
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            Padding="16">

                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Accent strip -->
                                <Rectangle
                                Grid.Column="0"
                                RadiusX="2"
                                RadiusY="2"
                                Fill="{ThemeResource SystemAccentColor}" />

                                <StackPanel Grid.Column="1" Spacing="12">
                                    <!-- Header + connect switch -->
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE705;" />
                                            <TextBlock Text="连接" Style="{StaticResource SubtitleTextBlockStyle}" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="8">
                                            <ProgressRing IsActive="{x:Bind viewModel.Loading, Mode=OneWay}" Width="16" Height="16"/>
                                            <ToggleSwitch
                                            OnContent="已连接"
                                            OffContent="未连接"
                                            IsEnabled="{x:Bind viewModel.CanToggleVpn, Mode=OneWay}"
                                            IsOn="{x:Bind viewModel.IsConnected, Mode=OneWay}"
                                            MinWidth="0"
                                            Width="Auto"
                                            Toggled="ConnectToggleSwitch_Toggled" />
                                        </StackPanel>
                                    </Grid>

                                    <!-- Higher-density info -->
                                    <Grid ColumnSpacing="16" RowSpacing="10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <Grid Grid.Column="0" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE753;" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="服务器" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind viewModel.ServerUrl}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid Grid.Column="1" ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <FontIcon Grid.Column="0" Glyph="&#xE77B;" />
                                            <StackPanel Grid.Column="1" Spacing="2">
                                                <TextBlock Text="身份" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind viewModel.Identity}" TextTrimming="CharacterEllipsis" />
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- 状态 -->
                    <Grid x:Name="RightCard" Grid.Column="1">
                        <Border
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Background="Black"
                            Opacity="{StaticResource CardShadowOpacity}"
                            Margin="{StaticResource CardShadowMargin}"
                            IsHitTestVisible="False" />

                        <Border
                            CornerRadius="{StaticResource CardCornerRadius}"
                            Background="{ThemeResource CardBackgroundFillColorDefault}"
                            BorderThickness="1"
                            BorderBrush="{ThemeResource CardStrokeColorDefault}"
                            Padding="16">
                            <StackPanel Spacing="12">
                                <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE946;" />
                                    <TextBlock Text="状态" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>

                                <StackPanel Spacing="6">
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="提示" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        TextWrapping="Wrap"
                                        Text="连接过程中会创建虚拟网卡；断开后会释放资源。若连接失败，请检查服务器地址/端口与加密模式。" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- 流量统计：累计与速率均为隧道 payload；速率由 UI 定时采样估算 -->
                <Grid>
                    <Border
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Background="Black"
                        Opacity="{StaticResource CardShadowOpacity}"
                        Margin="{StaticResource CardShadowMargin}"
                        IsHitTestVisible="False" />
                    <Border
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        Padding="16">
                        <StackPanel Grid.Column="1" Spacing="14">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE704;" />
                                <TextBlock Text="流量统计" Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>

                            <Grid ColumnSpacing="20" RowSpacing="14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="已上传" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind viewModel.TrafficUploadedDisplay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74B;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="已下载" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind viewModel.TrafficDownloadedDisplay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74A;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="上传速度" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind viewModel.TrafficUploadSpeedDisplay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE74B;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="下载速度" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind viewModel.TrafficDownloadSpeedDisplay}" Style="{StaticResource SubtitleTextBlockStyle}" />
                                </StackPanel>
                            </Grid>

                            <controls:TrafficLineChart
                                Margin="0,10,0,0"
                                Height="180"
                                UploadSeries="{x:Bind viewModel.UploadSpeedSeries, Mode=OneWay}"
                                DownloadSeries="{x:Bind viewModel.DownloadSpeedSeries, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Peers -->
                <Grid>
                    <Border
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Background="Black"
                        Opacity="{StaticResource CardShadowOpacity}"
                        Margin="{StaticResource CardShadowMargin}"
                        IsHitTestVisible="False" />
                    <Border
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                        Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE902;" />
                                <TextBlock Text="Peers（预留）" Style="{StaticResource SubtitleTextBlockStyle}" />
                            </StackPanel>
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="暂未实现：后续可展示对端列表与实时流量统计。" />
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
