<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Rustun.Views.Pages.PeersPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Rustun.Views.Pages"
    xmlns:controls="using:Rustun.Controls"
    xmlns:vm="using:Rustun.ViewModels.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Page.Resources>
        <x:Double x:Key="VerticalSpacing">8</x:Double>
        <x:Double x:Key="CardSpacing">12</x:Double>
        <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
        <x:Double x:Key="CardShadowOpacity">0.10</x:Double>
        <Thickness x:Key="CardShadowMargin">0,3,0,0</Thickness>
        <x:Double x:Key="PeerCardMinWidth">320</x:Double>

        <!-- Status pill brushes (use accent only; avoids unknown theme resources) -->
        <SolidColorBrush x:Key="PillAccentBgBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.14" />
        <SolidColorBrush x:Key="PillAccentStrokeBrush" Color="{ThemeResource SystemAccentColor}" Opacity="0.70" />
        <SolidColorBrush x:Key="PillAccentTextBrush" Color="{ThemeResource SystemAccentColor}" />
    </Page.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid MaxWidth="1064" Margin="36,24,36,0">
            <StackPanel Spacing="2">
                <TextBlock x:Name="PageHeader" AutomationProperties.HeadingLevel="Level1" Style="{StaticResource TitleTextBlockStyle}" Text="Peers" />
            </StackPanel>
        </Grid>

        <ScrollView Grid.Row="1" Padding="36,0,36,0" VerticalScrollBarVisibility="Auto" VerticalScrollMode="Auto">
            <StackPanel MaxWidth="1064" Spacing="{StaticResource CardSpacing}" Padding="0,24,0,36">
                <!-- Peers -->
                <StackPanel Spacing="{StaticResource CardSpacing}">
                    <!-- Empty state -->
                    <controls:PeersEmptyState
                        Padding="0,16,0,0"
                        Title="{x:Bind viewModel.EmptyTitle, Mode=OneWay}"
                        Description="{x:Bind viewModel.EmptyDescription, Mode=OneWay}"
                        Visibility="{x:Bind viewModel.ToVisibility(viewModel.IsPeerEmpty), Mode=OneWay}" />

                    <ItemsRepeater ItemsSource="{x:Bind viewModel.PeerCards, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <!-- 够宽时多列；不够宽时自动退化为单列 -->
                            <UniformGridLayout
                                MinColumnSpacing="{StaticResource CardSpacing}"
                                MinRowSpacing="{StaticResource CardSpacing}"
                                MinItemWidth="{StaticResource PeerCardMinWidth}"
                                ItemsJustification="Start" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="vm:PeerCardViewModel">
                                <Grid MinWidth="{StaticResource PeerCardMinWidth}">
                                    <Border
                                        CornerRadius="{StaticResource CardCornerRadius}"
                                        Background="{ThemeResource CardBackgroundFillColorDefault}"
                                        BorderThickness="1"
                                        BorderBrush="{ThemeResource CardStrokeColorDefault}"
                                        Padding="16">
                                        <StackPanel Spacing="24">
                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE77B;" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="Identity" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind Identity}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE839;" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="Private IP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind PrivateIp}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE8F7;" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="IPv6" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind Ipv6}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE8CB;" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="CIDRs" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind CidersDisplay}" />
                                                </StackPanel>
                                            </Grid>

                                            <Grid ColumnSpacing="10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Grid.Column="0" Glyph="&#xE81C;" />
                                                <StackPanel Grid.Column="1" Spacing="2">
                                                    <TextBlock Text="Last active" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" />
                                                    <TextBlock Text="{x:Bind LastActiveDisplay}" />
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>
            </StackPanel>
        </ScrollView>
    </Grid>
</Page>
